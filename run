#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

[[ -f "$ROOT_DIR/abstracts/$OS.sh" ]] || {
  echo "unsupported OS: $OS" >&2
  exit 1
}

source_modules \
  abstracts/$OS.sh \
  utils/network.sh \
  utils/pair.sh \
  utils/resolve.sh \
  utils/table.sh \
  prepares/environments.sh \
  prepares/local.sh \
  checks/local.sh \
  checks/neighbors.sh

main() {
  prepare_environment_context
  prepare_local_context
  check_local
  check_neighbors
}

main "$@"
