#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

source_modules \
  utils/path.sh \
  profiles/common.sh \
  hosts/common.sh

main() {
  path_prepare
  if [ "$#" -eq 0 ]; then
    exit 1
  fi
  host_run_alias "$@"
}

main "$@"
