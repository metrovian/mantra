#!/usr/bin/env bash
set -eu

ROOT_DIR=$(
  cd "$(dirname "$0")"
  pwd
)

source "$ROOT_DIR/utils/output.sh"
source "$ROOT_DIR/utils/path.sh"
source "$ROOT_DIR/profile/common.sh"
source "$ROOT_DIR/host/common.sh"

usage() {
  cat <<'EOF'
usage:
  run <alias> [ssh args...]
EOF
}

main() {
  path_prepare
  if [ "$#" -eq 0 ]; then
    usage
    exit 1
  fi
  host_run_alias "$@"
}

main "$@"
