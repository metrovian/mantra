#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/output.sh \
  utils/path.sh \
  profiles/common.sh \
  hosts/common.sh

usage() {
  echo "$0 <alias> [ssh args...]"
  exit 1
}

main() {
  path_prepare
  if [ "$#" -eq 0 ]; then
    usage
  fi
  host_run_alias "$@"
}

main "$@"
