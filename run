#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

[[ -f "$ROOT_DIR/abstract/$OS.sh" ]] || {
  echo "unsupported OS: $OS" >&2
  exit 1
}

source_modules \
  abstract/$OS.sh \
  abstract/network.sh \
  abstract/lookup.sh \
  abstract/resolve.sh \
  abstract/pair.sh \
  abstract/table.sh \
  prepare/local.sh \
  check/local.sh \
  check/dns.sh \
  check/neighbors.sh
prepare_local_context
check_local
check_dns
check_neighbors
