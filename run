#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s)"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "usage: run"
  exit 0
fi

if [[ "$OS" == "Linux" ]]; then
  source "$ROOT_DIR/abstract/linux/inspect.sh"
  source "$ROOT_DIR/abstract/linux/lookup.sh"
  source "$ROOT_DIR/abstract/linux/resolve.sh"
elif [[ "$OS" == "Darwin" ]]; then
  source "$ROOT_DIR/abstract/macos/inspect.sh"
  source "$ROOT_DIR/abstract/macos/lookup.sh"
  source "$ROOT_DIR/abstract/macos/resolve.sh"
else
  echo "unsupported OS: $OS" >&2
  exit 1
fi

source "$ROOT_DIR/format/section.sh"
source "$ROOT_DIR/format/table.sh"
source "$ROOT_DIR/prepare/local_network.sh"
source "$ROOT_DIR/check/local_network.sh"
source "$ROOT_DIR/check/dns.sh"
source "$ROOT_DIR/check/subnet_neighbors.sh"

prepare_local_network_context
check_local_network
check_dns
check_subnet_neighbors
