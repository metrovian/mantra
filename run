#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s)"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "usage: run"
  exit 0
fi

if [[ "$OS" == "Linux" ]]; then
  # shellcheck source=/dev/null
  source "$ROOT_DIR/platform/linux/local.sh"
elif [[ "$OS" == "Darwin" ]]; then
  # shellcheck source=/dev/null
  source "$ROOT_DIR/platform/macos/local.sh"
else
  echo "unsupported OS: $OS" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$ROOT_DIR/prepare/local_network.sh"
# shellcheck source=/dev/null
source "$ROOT_DIR/check/local_network.sh"
# shellcheck source=/dev/null
source "$ROOT_DIR/check/subnet_neighbors.sh"

prepare_local_network_context
check_local_network
check_subnet_neighbors
