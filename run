#!/usr/bin/env bash
set -eu

ROOT_DIR=$(
  cd "$(dirname "$0")"
  pwd
)

source "$ROOT_DIR/utils/output.sh"
source "$ROOT_DIR/utils/path.sh"
source "$ROOT_DIR/profiles/common.sh"
source "$ROOT_DIR/hosts/common.sh"

usage() {
  echo "$0 <alias> [ssh args...]"
}

main() {
  path_prepare
  if [ "$#" -eq 0 ]; then
    usage
    exit 1
  fi
  host_run_alias "$@"
}

main "$@"
