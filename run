#!/usr/bin/env bash
set -eu

ROOT_DIR=$(
  cd "$(dirname "$0")"
  pwd
)

source "$ROOT_DIR/utils/output.sh"
source "$ROOT_DIR/utils/path.sh"
source "$ROOT_DIR/utils/config.sh"
source "$ROOT_DIR/utils/ssh.sh"

usage() {
  cat <<'EOF'
usage:
  run <alias> [ssh args...]
EOF
}

main() {
  path_prepare
  if [ "$#" -eq 0 ]; then
    usage
    exit 1
  fi
  run_host_alias "$@"
}

main "$@"
