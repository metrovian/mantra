#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

[[ -f "$ROOT_DIR/abstract/$OS.sh" ]] || {
  echo "unsupported OS: $OS" >&2
  exit 1
}

source_modules \
  abstract/$OS.sh \
  abstract/network.sh \
  abstract/lookup.sh \
  abstract/resolve.sh \
  abstract/pair.sh \
  abstract/table.sh \
  prepare/local_network.sh \
  check/local_network.sh \
  check/gateway.sh \
  check/dns.sh \
  check/subnet_neighbors.sh
prepare_local_network_context
check_local_network
check_gateway
check_dns
check_subnet_neighbors
