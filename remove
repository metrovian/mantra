#!/bin/bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <path>" >&2
  exit 1
}

main() {
  local path="${1:-}"
  [ -n "$path" ] || usage
  git -C "$ROOT_DIR" submodule deinit -f -- "$path"
  git -C "$ROOT_DIR" rm -f -- "$path"
  rm -rf "$ROOT_DIR/.git/modules/$path"
}

main "$@"
