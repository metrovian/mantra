#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <profile> <alias> <user> <hostname>" >&2
  exit 1
}

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

source_modules \
  utils/path.sh \
  utils/validate.sh \
  profiles/common.sh \
  hosts/common.sh

main() {
  path_prepare
  validate_require_arg_count "$#" 4 || usage
  validate_names "$1" "$2" "$3"
  profile_require "$1"
  if host_exists "$1" "$2"; then
    exit 1
  fi
  host_add "$1" "$2" "$3" "$4"
  exec "$ROOT_DIR/status" "$1"
}

main "$@"
