#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <profile> <alias>" >&2
  exit 1
}

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

source_modules \
  utils/host.sh \
  utils/path.sh \
  utils/profile.sh \
  utils/validate.sh

main() {
  path_prepare
  validate_require_arg_count "$#" 2 || usage
  validate_names "$1" "$2"
  profile_require "$1"
  if ! host_exists "$1" "$2"; then
    exit 1
  fi
  host_remove "$1" "$2"
  exec "$ROOT_DIR/status" "$1"
}

main "$@"
