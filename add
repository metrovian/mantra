#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <name>" >&2
  exit 1
}

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

source_modules \
  utils/path.sh \
  utils/validate.sh \
  profiles/common.sh

main() {
  path_prepare
  validate_require_arg_count "$#" 1 || usage
  validate_names "$1"
  if profile_exists "$1"; then
    exit 1
  fi
  profile_add "$1"
  exec "$ROOT_DIR/status"
}

main "$@"
