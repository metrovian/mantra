#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s)"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "usage: check"
  exit 0
fi

if [[ "$OS" == "Linux" ]]; then
  # shellcheck source=/dev/null
  . "$ROOT_DIR/platform/linux/local.sh"
elif [[ "$OS" == "Darwin" ]]; then
  # shellcheck source=/dev/null
  . "$ROOT_DIR/platform/macos/local.sh"
else
  echo "unsupported OS: $OS" >&2
  exit 1
fi

detect_network

if [[ -z "${GATEWAY:-}" || -z "${IFACE:-}" || -z "${LOCAL_IP:-}" ]]; then
  echo "could not detect gateway or local IPv4 address." >&2
  exit 1
fi

SUBNET_PREFIX="$(awk -F. '{print $1 "." $2 "." $3}' <<<"$GATEWAY")"

echo "time      $(date '+%Y-%m-%d %H:%M:%S %Z')"
echo "interface $IFACE"
echo "me        $LOCAL_IP"
echo "gateway   $GATEWAY"
echo "subnet    ${SUBNET_PREFIX}.0/24"
echo

for host in $(seq 1 254); do
  ping_host "${SUBNET_PREFIX}.${host}" &
done

wait

printf "%-15s %-17s %-30s %s\n" \
  "IP" "MAC" "company" "hostname"
printf "%-15s %-17s %-30s %s\n" \
  "---------------" \
  "-----------------" \
  "------------------------------" \
  "--------------------------------"

for host in $(seq 1 254); do
  ip="${SUBNET_PREFIX}.${host}"
  mac="$(lookup_mac "$ip")"

  if [[ -n "${mac:-}" && "$mac" != "(incomplete)" ]]; then
    hostname="$(lookup_hostname "$ip")"
    company="$(lookup_company "$mac")"
    printf "%-15s %-17s %-30s %s\n" "$ip" "$mac" "${company:--}" "${hostname:--}"
  fi
done
