#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/output.sh \
  utils/path.sh \
  utils/validate.sh \
  profiles/common.sh \
  hosts/common.sh

main() {
  path_prepare
  validate_require_arg_count "$#" 4 "<profile> <alias> <user> <hostname>"
  validate_names "$1" "$2" "$3"
  profile_require "$1"
  if host_exists "$1" "$2"; then
    exit 1
  fi
  host_add "$1" "$2" "$3" "$4"
  exec "$ROOT_DIR/status" "$1"
}

main "$@"
