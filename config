#!/usr/bin/env bash
set -eu

ROOT_DIR=$(
  cd "$(dirname "$0")"
  pwd
)

source "$ROOT_DIR/utils/output.sh"
source "$ROOT_DIR/utils/path.sh"
source "$ROOT_DIR/utils/validate.sh"
source "$ROOT_DIR/profile/common.sh"
source "$ROOT_DIR/utils/ssh.sh"

usage() {
  cat <<'EOF'
usage:
  config current
  config profile list
  config profile add <name>
  config profile remove <name>
  config profile switch <name>
  config host list [profile]
  config host add <profile> <alias> <user> <hostname>
  config host remove <profile> <alias>
EOF
}

main() {
  path_prepare
  if [ "$#" -eq 0 ]; then
    usage
    exit 1
  fi
  case "$1" in
    current)
      shift
      bash "$ROOT_DIR/profile/current.sh" "$@"
      ;;
    profile)
      shift
      bash "$ROOT_DIR/profile/main.sh" "$@"
      ;;
    host)
      shift
      bash "$ROOT_DIR/host/main.sh" "$@"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
