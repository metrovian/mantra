#!/usr/bin/env bash
set -eu

ROOT_DIR=$(
  cd "$(dirname "$0")"
  pwd
)

. "$ROOT_DIR/utils/output.sh"
. "$ROOT_DIR/utils/path.sh"
. "$ROOT_DIR/utils/validate.sh"
. "$ROOT_DIR/utils/config.sh"
. "$ROOT_DIR/utils/ssh.sh"

usage() {
  cat <<'EOF'
usage:
  config current
  config profile list
  config profile add <name>
  config profile remove <name>
  config profile switch <name>
  config host list [profile]
  config host add <profile> <alias> <user> <hostname>
  config host remove <profile> <alias>
  config <alias> [ssh args...]
EOF
}

main() {
  marionette_init_paths
  marionette_ensure_layout
  if [ "$#" -eq 0 ]; then
    usage
    exit 1
  fi
  case "$1" in
    current)
      shift
      bash "$ROOT_DIR/profile/current.sh" "$@"
      ;;
    profile)
      shift
      bash "$ROOT_DIR/profile/main.sh" "$@"
      ;;
    host)
      shift
      bash "$ROOT_DIR/host/main.sh" "$@"
      ;;
    *)
      run_host_alias "$1" "${@:2}"
      ;;
  esac
}

main "$@"
