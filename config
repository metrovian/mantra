#!/usr/bin/env bash
set -eu

ROOT_DIR=$(
  cd "$(dirname "$0")"
  pwd
)

. "$ROOT_DIR/utils/output.sh"
. "$ROOT_DIR/utils/path.sh"
. "$ROOT_DIR/utils/validate.sh"
. "$ROOT_DIR/utils/config.sh"
. "$ROOT_DIR/utils/ssh.sh"

usage() {
  cat <<'EOF'
usage:
  marionette current
  marionette profile list
  marionette profile add <name>
  marionette profile remove <name>
  marionette profile switch <name>
  marionette host list [profile]
  marionette host add <profile> <alias> <hostname>
  marionette host remove <profile> <alias>
EOF
}

main() {
  marionette_init_paths
  marionette_ensure_layout
  if [ "$#" -eq 0 ]; then
    usage
    exit 1
  fi
  case "$1" in
    current)
      shift
      bash "$ROOT_DIR/profile/current.sh" "$@"
      ;;
    profile)
      shift
      bash "$ROOT_DIR/profile/main.sh" "$@"
      ;;
    host)
      shift
      bash "$ROOT_DIR/host/main.sh" "$@"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
