#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 [profile]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/../utils/source.sh"
source_modules \
  ../utils/filesystem.sh \
  ../utils/host.sh \
  ../utils/profile.sh \
  ../utils/ssh.sh \
  ../utils/table.sh \
  ../utils/validate.sh

status_add_host_row() {
  local alias
  local user
  local fingerprint
  alias=$1
  user=$2
  fingerprint=${4:--}
  table_add_row "$alias" "$user" "$fingerprint"
}

main() {
  local selected
  local name
  local profile
  filesystem_prepare
  validate_require_arg_max "$#" 1 || usage
  if [ "$#" -eq 1 ]; then
    selected=$1
  else
    selected=$(profile_current) || selected=
  fi
  if [ -n "$selected" ]; then
    profile_require "$selected"
  fi
  table_reset
  table_set_headers PROFILE HOST
  for name in $(profile_list); do
    profile=$name
    if [ "$name" = "$selected" ]; then
      profile="$name*"
    fi
    table_add_row "$profile" "$(host_count "$name")"
  done
  table_print
  if [ -z "$selected" ]; then
    exit 0
  fi
  echo
  table_reset
  table_set_headers ALIAS USER SSH
  host_each "$selected" status_add_host_row
  table_print
}

main "$@"
