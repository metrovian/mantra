#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <profile> <alias> <user> <hostname>" >&2
  exit 1
}

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

source_modules \
  ../utils/host.sh \
  ../utils/path.sh \
  ../utils/profile.sh \
  ../utils/ssh.sh \
  ../utils/validate.sh

main() {
  local fingerprint
  path_prepare
  validate_require_arg_count "$#" 4 || usage
  validate_names "$1" "$2" "$3"
  profile_require "$1"
  if host_exists "$1" "$2"; then
    exit 1
  fi
  fingerprint=$(host_prepare_connection "$1" "$4")
  host_add "$1" "$2" "$3" "$4" "$fingerprint"
  exec "$ROOT_DIR/status" "$1"
}

main "$@"
