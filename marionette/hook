#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <alias> <user> <hostname>" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/../utils/source.sh"
source_modules \
  ../utils/host.sh \
  ../utils/profile.sh \
  ../utils/ssh.sh \
  ../utils/validate.sh

main() {
  local fingerprint
  [ "$#" -eq 3 ] || usage
  validate_names "$1" "$2"
  profile_prepare
  if host_exists "$1"; then
    exit 1
  fi
  fingerprint=$(host_prepare_connection "$1" "$3")
  host_add "$1" "$2" "$3" "$fingerprint"
  exec "$ROOT_DIR/status"
}

main "$@"
