#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <profile> <alias>" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/../utils/source.sh"
source_modules \
  ../utils/filesystem.sh \
  ../utils/host.sh \
  ../utils/profile.sh \
  ../utils/ssh.sh \
  ../utils/validate.sh

main() {
  [ "$#" -eq 2 ] || usage
  validate_names "$1" "$2"
  profile_prepare
  profile_require "$1"
  if ! host_exists "$1" "$2"; then
    exit 1
  fi
  host_remove "$1" "$2"
  exec "$ROOT_DIR/status" "$1"
}

main "$@"
