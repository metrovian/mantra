#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <alias> [ssh args...]" >&2
  exit 1
}

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

source_modules \
  ../utils/host.sh \
  ../utils/path.sh \
  ../utils/profile.sh \
  ../utils/ssh.sh

main() {
  path_prepare
  if [ "$#" -eq 0 ]; then
    usage
  fi
  host_run_alias "$@"
}

main "$@"
