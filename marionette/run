#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "$0 <alias> [ssh args...]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/../utils/source.sh"
source_modules \
  ../utils/filesystem.sh \
  ../utils/host.sh \
  ../utils/profile.sh \
  ../utils/ssh.sh

main() {
  [ "$#" -ge 1 ] || usage
  filesystem_prepare
  host_run_alias "$@"
}

main "$@"
