#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

source_modules() {
  local module
  for module in "$@"; do
    # shellcheck source=/dev/null
    source "$ROOT_DIR/$module"
  done
}

[[ -f "$ROOT_DIR/../utils/abstracts/$OS.sh" ]] || exit 1
source_modules \
  ../utils/abstracts/$OS.sh \
  ../utils/marionette.sh \
  ../utils/network.sh \
  ../utils/pair.sh \
  ../utils/table.sh

main() {
  local neighbors
  if [[ $# -eq 0 ]]; then
    network_local
    return 0
  fi
  neighbors="$(network_neighbors_records "$@")"
  marionette_sync "$neighbors"
  network_neighbors_print "$neighbors"
}

main "$@"
