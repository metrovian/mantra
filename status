#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/path.sh \
  utils/table.sh \
  utils/validate.sh \
  profiles/common.sh \
  hosts/common.sh

status_add_host_row() {
  local alias
  local user
  local hostname
  alias=$1
  user=$2
  hostname=$3
  table_add_row "$hostname" "$user" "$alias"
}

main() {
  local selected
  local name
  local profile
  path_prepare
  validate_require_arg_max "$#" 1 "[profile]"
  if [ "$#" -eq 1 ]; then
    selected=$1
  else
    selected=$(profile_current) || selected=
  fi
  if [ -n "$selected" ]; then
    profile_require "$selected"
  fi
  table_reset
  table_set_headers PROFILE HOST
  for name in $(profile_list); do
    profile=$name
    if [ "$name" = "$selected" ]; then
      profile="$name*"
    fi
    table_add_row "$profile" "$(host_count "$name")"
  done
  table_print
  if [ -z "$selected" ]; then
    exit 0
  fi
  echo
  table_reset
  table_set_headers IP USER ALIAS
  host_each "$selected" status_add_host_row
  table_print
}

main "$@"
