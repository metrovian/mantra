#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/output.sh \
  utils/path.sh \
  utils/table.sh \
  utils/validate.sh \
  profiles/common.sh \
  hosts/common.sh

status_add_profile_row() {
  local name
  local selected
  local profile
  name=$1
  selected=$2
  profile=$name
  if [ "$name" = "$selected" ]; then
    profile="$name*"
  fi
  table_add_row "$profile" "$(host_count "$name")"
}

host_add_table_row() {
  local alias
  local user
  local hostname
  alias=$1
  user=$2
  hostname=$3
  table_add_row "$hostname" "$user" "$alias"
}

main() {
  local current
  local profile
  local name
  path_prepare
  validate_require_arg_max "$#" 1 "[profile]"
  current=$(profile_current) || current=
  if [ "$#" -eq 1 ]; then
    profile=$1
  else
    profile=$current
  fi
  table_reset
  table_set_headers PROFILE HOST
  for name in $(profile_list); do
    status_add_profile_row "$name" "$profile"
  done
  table_print
  if [ -z "$profile" ]; then
    exit 0
  fi
  profile_require "$profile"
  echo
  table_reset
  table_set_headers IP USER ALIAS
  host_each "$profile" host_add_table_row
  table_print
}

main "$@"
