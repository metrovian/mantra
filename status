#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"

source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/output.sh \
  utils/path.sh \
  utils/pair.sh \
  utils/table.sh \
  utils/validate.sh \
  profiles/common.sh \
  hosts/common.sh

host_add_table_row() {
  local alias
  local user
  local hostname
  alias=$1
  user=$2
  hostname=$3
  table_add_row "$hostname" "$user" "$alias"
}

main() {
  local profile
  path_prepare
  validate_require_arg_max "$#" 1 "[profile]"
  if [ "$#" -eq 1 ]; then
    profile=$1
  else
    profile=$(profile_current_or_die)
  fi
  profile_require "$profile"
  pair_reset
  pair_set_title STATUS
  pair_add profile "$profile"
  pair_add host "$(host_count "$profile")"
  pair_print
  table_reset
  table_set_headers IP USER ALIAS
  host_each "$profile" host_add_table_row
  table_print
}

main "$@"
